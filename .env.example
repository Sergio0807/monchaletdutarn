# Variables d'environnement — à configurer dans Vercel (Settings → Environment Variables)
# puis localement dans un fichier .env.local (NE PAS committer .env.local)

# Clé API Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Destinataire des demandes (agent)
LEAD_TO=christophe.digue@batimmo.fr

# Expéditeur — doit être un domaine vérifié dans Resend
# (configurez le domaine monchaletdutarn.fr dans Resend, ou utilisez onboarding@resend.dev en test)
LEAD_FROM=contact@monchaletdutarn.fr
